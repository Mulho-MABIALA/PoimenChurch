APP_NAME="Poimen Church"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database - Railway fournit ces variables automatiquement avec le service MySQL
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# Redis - Ajouter le service Redis sur Railway, les variables sont auto-injectées
# En local : installer Redis puis utiliser 127.0.0.1:6379
REDIS_CLIENT=phpredis
REDIS_HOST=${REDISHOST}
REDIS_PASSWORD=${REDISPASSWORD}
REDIS_PORT=${REDISPORT}

# Sessions via Redis : élimine les écritures DB sur chaque requête HTTP
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue via Redis : évite de bloquer la DB avec les jobs
QUEUE_CONNECTION=redis

# Cache via Redis : requêtes dashboard mises en cache, pas en DB
CACHE_STORE=redis

VITE_APP_NAME="${APP_NAME}"
